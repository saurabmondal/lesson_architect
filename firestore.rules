rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidLessonPlan(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'preliminaryInformation'])
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid;
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'activities', 'classLevel', 'subject'])
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid;
    }

    function isValidQuestionPaperLog(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'paper', 'classLevel', 'subject'])
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid;
    }

    match /lessonPlans/{lessonPlanId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      allow get: if isAuthenticated() && isValidId(lessonPlanId) && resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() 
        && isValidId(lessonPlanId)
        && isValidLessonPlan(incoming())
        && incoming().createdAt == request.time
        && incoming().keys().hasOnly(['userId', 'createdAt', 'preliminaryInformation', 'instructionalObjectives', 'entryBehaviour', 'instructionalAids', 'instructionalProcedure', 'summary', 'activities', 'finalEvaluation']);

      allow update: if isAuthenticated()
        && isValidId(lessonPlanId)
        && isValidLessonPlan(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['preliminaryInformation', 'instructionalObjectives', 'entryBehaviour', 'instructionalAids', 'instructionalProcedure', 'summary', 'activities', 'finalEvaluation']);

      allow delete: if isAuthenticated() && isValidId(lessonPlanId) && existing().userId == request.auth.uid;
    }

    match /activities/{activityId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && isValidId(activityId) && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && isValidId(activityId)
        && isValidActivityLog(incoming())
        && incoming().createdAt == request.time
        && incoming().keys().hasOnly(['userId', 'createdAt', 'activities', 'classLevel', 'subject', 'lesson', 'topic']);
      allow update: if isAuthenticated()
        && isValidId(activityId)
        && isValidActivityLog(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['activities', 'classLevel', 'subject', 'lesson', 'topic']);
      allow delete: if isAuthenticated() && isValidId(activityId) && existing().userId == request.auth.uid;
    }

    match /questionPapers/{paperId} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && isValidId(paperId) && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && isValidId(paperId)
        && isValidQuestionPaperLog(incoming())
        && incoming().createdAt == request.time
        && incoming().keys().hasOnly(['userId', 'createdAt', 'paper', 'classLevel', 'subject']);
      allow update: if isAuthenticated()
        && isValidId(paperId)
        && isValidQuestionPaperLog(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['paper', 'classLevel', 'subject']);
      allow delete: if isAuthenticated() && isValidId(paperId) && existing().userId == request.auth.uid;
    }
  }
}

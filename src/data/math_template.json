          "cases": [
            "SSS",
            "SAS",
            "ASA"
          ]
        },
        "triangle_inequality": {
          "rule": "Sum of two sides > third side"
        }
      },
      "activities": [
        "Construct triangles"
      ],
      "evaluation": [
        "Check validity of triangle"
      ],
      "summary": [
        "Triangle must satisfy inequality"
      ]
    }
  ]

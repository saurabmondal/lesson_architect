          "definition": "All sides equal",
          "properties": [
            "All angles are 60°"
          ]
        }
      },
      "activities": [
        "Construct triangle"
      ],
      "evaluation": [
        "Define equilateral triangle"
      ],
      "summary": [
        "All sides and angles equal"
      ]
    },
